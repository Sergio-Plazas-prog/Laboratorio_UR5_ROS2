<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="rosbot">

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 1.5708"/>
      <geometry>
        <!-- Esto es un comentario escrito en un documento XML -->
        <mesh filename="package://mi_robot/meshes/rosbot/body.stl" scale="0.001 0.001 0.001"/>
        <!-- <box size="1.0 1.0 1.0"/> -->
      </geometry> 
    </visual>

        <!-- Cubierta -->
    <visual>
      <origin xyz="0 0 0.06" rpy="1.5708 0 1.5708"/>
      <geometry>
        <mesh filename="package://mi_robot/meshes/rosbot/cover.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.20 0.15 0.06"/> </geometry>
    </collision>

    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>
    <!-- Gazebo material para calcular la friccion -->
  <gazebo reference="base_link">
    <material>Gazebo/Red</material>
  </gazebo>

  <!-- Ruedas --> 
  <xacro:macro name="wheel" params="prefix x_reflect y_reflect">
    <joint name="${prefix}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_link"/>
      <origin xyz="${x_reflect*0.09} ${y_reflect*0.09} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <link name="${prefix}_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://mi_robot/meshes/rosbot/wheel_a.dae" scale="1.0 1.0 1.0"/>
          <!-- <sphere radius="0.05"/> -->
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="0.04" length="0.03"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>
   <gazebo reference="${prefix}_link">
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
      <material>Gazebo/Black</material>
    </gazebo>
   
  </xacro:macro>

  <xacro:wheel prefix="front_left"  x_reflect="1"  y_reflect="1" />
  <xacro:wheel prefix="front_right" x_reflect="1"  y_reflect="-1" />
  <xacro:wheel prefix="rear_left"   x_reflect="-1" y_reflect="1" />
  <xacro:wheel prefix="rear_right"  x_reflect="-1" y_reflect="-1" />
  <!-- Driver-->
  <gazebo>
   <plugin
    filename="gz-sim-diff-drive-system"
    name="gz::sim::systems::DiffDrive">
    <left_joint>front_left_joint</left_joint>
    <right_joint>front_right_joint</right_joint>
    <wheel_separation>0.18</wheel_separation>
    <wheel_diameter>0.08</wheel_diameter>
    <topic>cmd_vel</topic>
    <odom_topic>odom</odom_topic>
    <frame_id>odom</frame_id>
    <child_frame_id>base_footprint</child_frame_id>
   </plugin>
  </gazebo>
</robot>
